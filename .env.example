# Firebase Configuration (Using existing credentials from code)

# AI API Keys (8 AI Models)

# Google Custom Search API
GOOGLE_CSE_API_KEY=your_google_cse_api_key
GOOGLE_CSE_CX=your_google_cse_cx

# Serper API (Alternative to Google CSE)
SERPER_API_KEY=your_serper_api_key

# Search Provider Configuration
SEARCH_PROVIDER=puppeteer

# Paddle Payment Configuration
PADDLE_API_KEY=your_paddle_api_key
PADDLE_ENVIRONMENT=sandbox
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=your_paddle_client_token
PADDLE_WEBHOOK_SECRET=your_paddle_webhook_secret
PADDLE_WEBHOOK_URL=https://growcitable.com/api/webhook

# Security Keys
ENCRYPTION_KEY=your_32_byte_encryption_key
SESSION_SECRET=your_session_secret

# Puppeteer Configuration
PUPPETEER_EXECUTABLE_PATH=
PUPPETEER_CACHE_DIR=
PUPPETEER_FORCE_HEADLESS=false
PUPPETEER_ALLOW_HEADFUL=true

# CAPTCHA Configuration
CAPTCHA_INTERACTIVE=true

# SERP Throttle
SERP_DELAY_MS=2500

# Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
